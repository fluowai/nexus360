// Nexus360 CRM 360 - Schema Completo para Agência de Geração de Leads

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Organization {
  id          String   @id @default(uuid())
  name        String
  domain      String?
  plan        String   @default("Free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  geminiKey   String?
  groqKey     String?
  aiProvider  String   @default("gemini")
  
  users       User[]
  leads       Lead[]
  projects    Project[]
  clients     Client[]
  opportunities Opportunity[]
  proposals   Proposal[]
  campaigns   Campaign[]
  tasks       Task[]
  invoices    Invoice[]
  contracts   Contract[]
  contractTemplates ContractTemplate[]
  sequences   Sequence[]
  creatives   Creative[]
  products    Product[]
  expenses   Expense[]
  notifications Notification[]
  calendarEvents CalendarEvent[]
  adAccounts   AdAccount[]
  assets      Asset[]
  assetFolders AssetFolder[]
  landingPages LandingPage[]
  quizzes     Quiz[]
  automations Automation[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String?
  password       String
  role           String       @default("USER") // SUPER_ADMIN, ORG_ADMIN, USER
  status         String       @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED

  avatarUrl      String?
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  managedLeads   Lead[]
  assignedTasks  Task[]
  managedClients Client[]
  managedOpportunities Opportunity[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Lead {
  id             String       @id @default(uuid())
  name           String
  email          String
  phone          String?
  status         String       @default("novo")
  value          Float        @default(0)
  tags           String?      
  source         String?
  notes          String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  followUps      FollowUp[]
  quizSubmissions QuizSubmission[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model FollowUp {
  id             String       @id @default(uuid())
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id])
  type           String
  content        String
  status         String       @default("pending")
  scheduledAt    DateTime?
  createdAt      DateTime     @default(now())
}

model Creative {
  id             String       @id @default(uuid())
  title          String
  type           String       // image, video, copy, carousel
  contentUrl     String?      // Link to file
  copyText       String?      
  status         String       @default("pending") // pending, approved, rejected, revision
  feedback       String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  campaignId     String?
  campaign       Campaign?     @relation(fields: [campaignId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Project {
  id             String       @id @default(uuid())
  title          String
  description    String?
  status         String       @default("planejamento")
  deadline       DateTime?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Client {
  id             String       @id @default(uuid())
  corporateName  String       // Razão Social
  tradeName      String?      // Nome Fantasia
  cnpj           String?      @unique
  cpf            String?
  email          String
  phone          String?
  website        String?
  
  // Endereço
  address        String?
  city           String?
  state          String?
  zipCode        String?
  
  // Dados Business
  segment        String?      // Segmento: Tech, Saúde, Retail, etc
  porte          String?      // Porte: MEI, Pequeno, Médio, Grande
  employees      Int?
  revenue        Float?
  
  // Dados do Responsável
  responsibleName  String?
  responsibleCpf   String?
  responsibleEmail String?
  responsiblePhone String?
  responsibleRole  String?

  // Status
  status         String       @default("prospect") // prospect, onboarding, ativo, inativo, churned
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  opportunities  Opportunity[]
  proposals      Proposal[]
  invoices       Invoice[]
  contracts      Contract[]
  soldProducts   SoldProduct[]
  demands        Demand[]
  
  notes          String?
  tags           String?
  
  // AI Context & History
  aiContext      ClientAIContext?
  aiGenerations  AIGeneration[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ClientAIContext {
  id              String   @id @default(uuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  context         Json     
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AIGeneration {
  id              String   @id @default(uuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  campaignId      String?
  agentType       String   
  
  prompt          String   
  response        String   
  
  createdAt       DateTime @default(now())
}

model Opportunity {
  id             String       @id @default(uuid())
  title          String
  description    String?
  
  stage          String       @default("qualificacao") // qualificacao, proposta, negociacao, fechado_ganho, fechado_perdido
  probability    Int          @default(10)
  
  value          Float        @default(0)
  estimatedValue Float?       
  
  expectedCloseDate DateTime?
  closedAt        DateTime?
  
  lostReason     String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Proposal {
  id             String       @id @default(uuid())
  title          String
  description    String?
  status         String       @default("rascunho")
  
  subtotal       Float        @default(0)
  discount       Float        @default(0)
  total          Float        @default(0)
  
  sentAt         DateTime?
  expiresAt      DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  
  items          ProposalItem[]
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ProposalItem {
  id             String       @id @default(uuid())
  proposalId     String
  proposal       Proposal     @relation(fields: [proposalId], references: [id])
  
  service        String       
  description    String?
  quantity       Int          @default(1)
  unitPrice      Float        @default(0)
  total          Float        @default(0)
  
  order          Int          @default(0)
}

model Campaign {
  id             String       @id @default(uuid())
  name           String
  description    String?
  type           String       
  status         String       @default("ativa")
  
  startDate      DateTime?
  endDate        DateTime?
  
  budget         Float        @default(0)
  spent          Float        @default(0)
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  leadsGenerated Int          @default(0)
  conversions    Int          @default(0)
  revenue        Float        @default(0)
  
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  creatives      Creative[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  status         String       @default("pendente")
  priority       String       @default("media")
  
  dueDate         DateTime?
  completedAt    DateTime?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  leadId         String?
  opportunityId  String?
  proposalId     String?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Invoice {
  id             String       @id @default(uuid())
  invoiceNumber  String       @unique
  status         String       @default("pendente")
  
  issueDate      DateTime     @default(now())
  dueDate        DateTime
  paidAt         DateTime?
  
  subtotal       Float        @default(0)
  discount       Float        @default(0)
  tax            Float        @default(0)
  total          Float        @default(0)
  
  description    String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SoldProduct {
  id              String   @id @default(uuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  
  name            String   
  setupValue      Float    @default(0)
  monthlyValue    Float    @default(0)
  commissionValue Float    @default(0)
  
  paymentMethod   String?
  billingDay      Int?
  contractTerm    Int?     
  startDate       DateTime @default(now())
  deliveryDate    DateTime?
  
  status          String   @default("onboarding")
  
  closerId        String?
  sdrId           String?
  
  contracts       Contract[]
  demands         Demand[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Contract {
  id             String   @id @default(uuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  soldProductId  String?
  soldProduct    SoldProduct? @relation(fields: [soldProductId], references: [id])
  templateId     String?
  template       ContractTemplate? @relation(fields: [templateId], references: [id])
  status         String   @default("draft") // draft, sent, signed, active, expired
  contractData   Json?    // Variáveis usadas no contrato
  aiComparison   String?  // Comparação da IA se múltiplos modelos foram analisados
  fileUrl        String?
  invoices       Invoice[]
  signedAt       DateTime?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  title          String?
  contractNumber String?     @unique
}

model ContractTemplate {
  id              String   @id @default(uuid())
  name            String
  content         String   @db.Text
  isActive        Boolean  @default(true)
  category        String?
  
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  
  contracts       Contract[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Demand {
  id              String   @id @default(uuid())
  title           String
  description     String?  @db.Text
  
  status          String   @default("pending")
  priority        String   @default("medium")
  
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  
  soldProductId   String?
  soldProduct     SoldProduct? @relation(fields: [soldProductId], references: [id])
  
  assignedToId    String?  
  aiAgentType     String?  
  
  aiResult        Json?
  
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Sequence {
  id             String       @id @default(uuid())
  name           String
  description    String?
  isActive       Boolean      @default(true)
  triggerType    String       
  
  steps          SequenceStep[]
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SequenceStep {
  id             String       @id @default(uuid())
  sequenceId     String
  sequence       Sequence     @relation(fields: [sequenceId], references: [id])
  
  order          Int
  type           String       
  subject        String?      
  body           String?      
  waitDays       Int?         
  condition      String?      
  
  createdAt      DateTime     @default(now())
}

model Product {
  id             String       @id @default(uuid())
  name           String
  description     String?
  sku            String?      @unique
  category       String?      
  unitPrice      Float        @default(0)
  unit           String?      
  stock          Int         @default(0)
  minStock       Int         @default(0)
  isActive       Boolean      @default(true)
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Expense {
  id             String       @id @default(uuid())
  description    String
  amount         Float
  category       String      
  date          DateTime     @default(now())
  status         String      @default("pendente")
  paidAt        DateTime?
  supplier       String?      
  document      String?      
  isRecurring   Boolean     @default(false)
  recurringType String?     
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Notification {
  id             String       @id @default(uuid())
  title          String
  message        String
  type           String       @default("info")
  isRead         Boolean      @default(false)
  link          String?      
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
}

model CalendarEvent {
  id             String       @id @default(uuid())
  title          String
  description    String?
  startDate      DateTime
  endDate       DateTime?
  allDay        Boolean     @default(false)
  type           String       
  status         String      @default("scheduled")
  reminder      Int?        
  
  leadId         String?
  taskId        String?
  projectId     String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  meetingRoom    String?
  meetingLink    String?
  
  createdAt      DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model AdAccount {
  id              String        @id @default(uuid())
  accountId        String        
  accountName     String
  platform        String        
  accountStatus  String       @default("active")
  accessToken    String?
  refreshToken   String?
  tokenExpiry    DateTime?
  accountCurrency String?
  accountTimezone String?
  dailySpendLimit Float      @default(0)
  currentSpend   Float      @default(0)
  
  organizationId  String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  campaigns      CampaignAd[]
  creatives     AdCreative[]
  audiences     CustomAudience[]
}

model CampaignAd {
  id             String       @id @default(uuid())
  campaignId     String
  name           String
  platform       String
  objective      String
  status        String        @default("paused")
  biddingStrategy String      @default("lowest_cost")
  startDate     DateTime?
  endDate       DateTime?
  budgetType    String       @default("daily")
  budgetAmount  Float       @default(0)
  spendAmount   Float       @default(0)
  locations    String?
  ageMin        Int          @default(18)
  ageMax        Int          @default(65)
  genders      String?
  interests    String?
  pixelId      String?
  conversionEvent String?
  
  adAccountId  String
  adAccount   AdAccount    @relation(fields: [adAccountId], references: [id])
  adSets       AdSet[]
  
  createdAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AdSet {
  id            String       @id @default(uuid())
  adSetId       String
  name          String
  status        String        @default("active")
  targeting     String?
  budgetType   String       @default("daily")
  budgetAmount Float       @default(0)
  
  campaignAdId String
  campaignAd  CampaignAd  @relation(fields: [campaignAdId], references: [id])
  ads         Ad[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Ad {
  id            String       @id @default(uuid())
  adId          String
  name          String
  status        String        @default("active")
  format        String        
  creativeId    String?
  creative     AdCreative?   @relation(fields: [creativeId], references: [id])
  adSetId      String
  adSet        AdSet        @relation(fields: [adSetId], references: [id])
  impressions  Int          @default(0)
  clicks       Int          @default(0)
  spend        Float        @default(0)
  conversions  Int          @default(0)
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AdCreative {
  id            String       @id @default(uuid())
  name          String
  type          String      
  imageUrl      String?
  videoUrl     String?
  thumbnailUrl String?
  headline     String?
  primaryText  String?
  description String?
  callToAction String?
  displayLink  String?
  destinationUrl String?
  platformData String?
  
  adAccountId  String
  adAccount   AdAccount    @relation(fields: [adAccountId], references: [id])
  ads         Ad[]
  
  createdAt   DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model CustomAudience {
  id             String       @id @default(uuid())
  audienceId     String
  name          String
  platform      String       
  description   String?
  audienceType  String       
  rule         String?
  sourceAudience String?
  size         Int          @default(0)
  
  adAccountId  String
  adAccount  AdAccount    @relation(fields: [adAccountId], references: [id])
  
  createdAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Asset {
  id            String       @id @default(uuid())
  name          String
  type          String       
  mimeType      String?
  size          Int?
  url           String?
  thumbnailUrl  String?
  width         Int?
  height        Int?
  duration      Int?
  tags          String?
  folderId      String?
  folder       AssetFolder?  @relation(fields: [folderId], references: [id])
  usedIn        String?
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt     DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AssetFolder {
  id             String       @id @default(uuid())
  name           String
  parentId       String?
  parent         AssetFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children       AssetFolder[] @relation("FolderHierarchy")
  assets        Asset[]
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt     DateTime     @default(now())
}

model LandingPage {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  templateId     String?
  template       LPTemplate?   @relation(fields: [templateId], references: [id])
  headline       String?
  subheadline    String?
  heroImage      String?
  heroVideo     String?
  content        String?      
  formId          String?
  form           LPForm?      @relation(fields: [formId], references: [id])
  formProvider   String?      
  formConfig     String?      
  status         String       @default("draft")
  views          Int          @default(0)
  submissions   Int          @default(0)
  conversionRate Float       @default(0)
  domain         String?
  customDomain  String?
  metaTitle     String?
  metaDescription String?
  metaImage    String?
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model LPTemplate {
  id            String        @id @default(uuid())
  name          String
  category      String        
  thumbnail     String?
  htmlTemplate  String?
  isActive      Boolean       @default(true)
  isPro         Boolean       @default(false)
  landingPages  LandingPage[]
  
  createdAt  DateTime     @default(now())
}

model LPForm {
  id              String        @id @default(uuid())
  name            String
  fields          String       
  submitAction    String       
  submitUrl       String?
  webhookUrl      String?
  emailTo         String?
  emailSubject    String?
  autoReply       Boolean      @default(false)
  replySubject    String?
  replyMessage   String?
  gdprConsent    Boolean      @default(false)
  gdprText       String?
  landingPages   LandingPage[]
  
  createdAt      DateTime     @default(now())
}

model Quiz {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  questions      QuizQuestion[]
  submissions    QuizSubmission[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model QuizQuestion {
  id             String       @id @default(uuid())
  quizId         String
  quiz           Quiz         @relation(fields: [quizId], references: [id])
  order          Int
  text           String
  type           String       // text, multiple_choice, single_choice
  options        Json?        
  createdAt      DateTime     @default(now())
}

model QuizSubmission {
  id             String       @id @default(uuid())
  quizId         String
  quiz           Quiz         @relation(fields: [quizId], references: [id])
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  answers        Json
  createdAt      DateTime     @default(now())
}

model Automation {
  id             String       @id @default(uuid())
  name           String
  description    String?
  isActive       Boolean      @default(true)
  triggerType    String       
  triggerConfig  Json?
  actions        Json
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
