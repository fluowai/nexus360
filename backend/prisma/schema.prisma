// MÓDULO: NEXUS PROSPECT AI
// ==========================================

model ProspectMission {
  id                      String    @id @default(uuid())
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id])
  userId                  String
  user                    User      @relation(fields: [userId], references: [id])
  name                    String
  niche                   String
  city                    String
  state                   String
  country                 String
  leadQuantity            Int
  executionDate           DateTime
  executionTime           String
  recurrence              String    @default("unica") // unica, diaria, semanal, quinzenal, mensal
  dailyMessageLimit       Int       @default(50)
  messageIntervalMinutes  Int       @default(15)
  minScore                Int       @default(50)
  initialApproach         String    @db.Text
  salesOwnerId            String?
  salesOwner              User?     @relation("MissionSalesOwner", fields: [salesOwnerId], references: [id])
  calendarId              String?   
  status                  String    @default("agendada") // agendada, em_execucao, pausada, concluida, erro, cancelada
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  leads                   ProspectLead[]
