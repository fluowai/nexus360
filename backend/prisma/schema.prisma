  metadata       Json?
  sentAt         DateTime?

  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([runId])
  @@index([capturedLeadId])
  @@index([status])
  @@index([createdAt])
}

model ProspectingOptOutContact {
