# =========================================================================
#                    NEXUS360 - ENVIRONMENT VARIABLES EXAMPLE
# =========================================================================
# Copy this file to '.env' and fill in your values.
# NEVER commit real credentials to the repository.
# Configure sensitive values via Portainer stack env vars or CI secrets.

# -----------------
# 1. CORE DATABASE & AUTH
# -----------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexus360_db?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/nexus360_db?schema=public"
JWT_SECRET="CHANGE_ME_TO_A_SECURE_RANDOM_STRING_64_CHARS"

# -----------------
# 2. SERVER & CORS
# -----------------
FRONTEND_URL="http://localhost:8080"
APP_URL="http://localhost:10000"
NODE_ENV="production"
PORT=10000
LOG_LEVEL="info"

# -----------------
# 3. REDIS CACHE (Required for production)
# -----------------
REDIS_URL="redis://redis:6379"
CACHE_TTL_MS=60000
MAX_CACHE_ITEMS=5000

# -----------------
# 4. AI CORE (LiteLLM)
# -----------------
AI_CORE_URL="http://litellm:4000/v1"
AI_CORE_DEFAULT_MODEL="gpt-4o-mini"

# External AI provider keys (set in secure environment, not in .env)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
SERPER_API_KEY=""
SERPAPI_API_KEY=""
OUTSCRAPER_API_KEY=""

# -----------------
# 5. TRAEFIK / WHITELABEL DOMAINS
# -----------------
WHITELABEL_DOCKER_IP=""
WHITELABEL_CNAME_TARGET=""
TRAEFIK_SYNC_MODE="docker-service"
TRAEFIK_ROUTER_SERVICE="nexus360_frontend"
TRAEFIK_ROUTER_LABEL_PREFIX="nexus360_custom"
TRAEFIK_DOCKER_NETWORK="nexus360"
DOCKER_SOCKET_PATH="/var/run/docker.sock"
TRAEFIK_DYNAMIC_DIR="/traefik/dynamic"
TRAEFIK_FRONTEND_URL="http://nexus360_frontend:80"
TRAEFIK_API_URL="http://nexus360_api:10000"
TRAEFIK_CERT_RESOLVER="letsencryptresolver"

# -----------------
# 6. WHATSAPP BRIDGE
# -----------------
WHATSAPP_BRIDGE_URL="http://whatsapp-bridge:8091"
WHATSAPP_BRIDGE_PUBLIC_URL="http://localhost:8091"
WHATSAPP_BRIDGE_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
NEXUS_BACKEND_URL="http://backend:10000"

# -----------------
# 7. GOOGLE MAPS SCRAPER
# -----------------
GOOGLE_MAPS_SCRAPER_URL="http://google-maps-scraper:8080"
GOOGLE_MAPS_SCRAPER_CONCURRENCY=2
GOOGLE_MAPS_SCRAPER_WORKERS=2
GOOGLE_MAPS_SCRAPER_BROWSER_POOL=1
GOOGLE_MAPS_SCRAPER_JOB_TIMEOUT_MS=240000

# -----------------
# 8. EXTERNAL INTEGRATIONS (Optional)
# -----------------
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_URL="wss://your-livekit-server.cloud"
CNPJ_WEBDAV_TOKEN=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
META_APP_ID=""
META_APP_SECRET=""
ADS_TOKEN_ENCRYPTION_KEY=""
ADS_SYNC_INTERVAL_MINUTES=30

# -----------------
# 9. STORAGE (MinIO)
# -----------------
MINIO_ENDPOINT=""
MINIO_PORT=443
MINIO_USE_SSL="true"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_PUBLIC_URL=""
MINIO_REGION="us-east-1"

# -----------------
# 10. FRONTEND BUILD TIME (frontend/.env)
# -----------------
VITE_API_URL="http://localhost:10000"
VITE_LIVEKIT_URL="wss://your-livekit-server.cloud"
