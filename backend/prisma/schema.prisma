  agents         AiAgent[] @relation("PrimaryAiModel")
  fallbackAgents AiAgent[] @relation("FallbackAiModel")
  entitlements   AiEntitlement[]
  usageLedgers   AiUsageLedger[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([provider])
  @@index([runtime])
  @@index([status])
}

