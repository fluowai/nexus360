// Nexus360 CRM 360 - Schema Completo para Agência de Geração de Leads

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  domain        String?  @unique
  logoUrl       String?
  faviconUrl    String?
  primaryColor  String?  @default("#3B82F6")
  secondaryColor String? @default("#1E40AF")
  
  whiteLabelConfig Json? // Configurações específicas de marca, emails, etc.
  settings         Json?

  organizations    Organization[]
  users            User[]
  plans            AgencyPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("CLIENT") // CLIENT | WHITELABEL
  slug      String?  @unique
  domain    String?
  plan      String   @default("Free")
  planId    String?
  planObj   Plan?    @relation(fields: [planId], references: [id])
  subscriptionStatus String   @default("TRIAL") // TRIAL, ACTIVE, PAST_DUE, SUSPENDED, CANCELED, EXPIRED
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  isActive           Boolean  @default(true)

  // White Label e Agency Hierarchy
  agencyId           String?
  agency             Agency?  @relation(fields: [agencyId], references: [id])
  
  whiteLabelConfig   Json?
  limitsUsage        Json?
  settings           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Controle de Versão e Lançamento
  isTestAccount Boolean @default(false)
  betaAccess    Boolean @default(false)

  // SaaS Relations
  saasSubscriptions SaaSSubscription[]
  auditLogs         AuditLog[]
  snapshots         Snapshot[]

  geminiKey  String?
  groqKey    String?
  serpApiKey String?
  serperApiKey String?
  outscraperKey String?
  aiProvider String  @default("gemini")

  users             User[]
  workspaces        Workspace[]
  accessProfiles    AccessProfile[]
  leads             Lead[]
  projects          Project[]
  clients           Client[]
  opportunities     Opportunity[]
  proposals         Proposal[]
  pipelines         Pipeline[]
  campaigns         Campaign[]
  tasks             Task[]
  invoices          Invoice[]
  contracts         Contract[]
  contractTemplates ContractTemplate[]
  sequences         Sequence[]
  creatives         Creative[]
  products          Product[]
  expenses          Expense[]
  notifications     Notification[]
  calendarEvents    CalendarEvent[]
  adAccounts        AdAccount[]
  adMetricSnapshots AdMetricSnapshot[]
  adsInsights       AdsInsight[]
  adsRecommendations AdsRecommendation[]
  clientReportShares ClientReportShare[]
  assets            Asset[]
  assetFolders      AssetFolder[]
  landingPages      LandingPage[]
  quizzes           Quiz[]
  automations       Automation[]
  promptTemplates   PromptTemplate[]
  generatedPrompts  GeneratedPrompt[]
  domains           Domain[]
  agendas           Agenda[]
  
  inboxes           Inbox[]
  usageEvents       UsageEvent[]
  aiAgents          AiAgent[]
  aiEntitlements    AiEntitlement[]
  aiUsageLedgers    AiUsageLedger[]
  aiQuotaWindows    AiQuotaWindow[]
  proposalTemplates ProposalTemplate[]
  onboardingGeneratedItems OnboardingGeneratedItem[]
  quickReplies      QuickReply[]
  automationLogs    AutomationLog[]
  
  leadCaptureSources    LeadCaptureSource[]
  capturedLeads         CapturedLead[]
  leadCaptureUsageLogs  LeadCaptureUsageLog[]
  companyIdentityCandidates CompanyIdentityCandidate[]
  companyIdentityAuditLogs  CompanyIdentityAuditLog[]
  prospectingFunnels    ProspectingFunnel[]
  prospectingRuns       ProspectingRun[]
  prospectingDecisionMakers ProspectingDecisionMaker[]
  prospectingDispatchAttempts ProspectingDispatchAttempt[]
  prospectingOptOutContacts ProspectingOptOutContact[]
  whatsappContactIdentities WhatsappContactIdentity[]
  whatsappGroupParticipants WhatsappGroupParticipant[]
  whatsappMentions WhatsappMention[]
  whatsappConnectionLogs WhatsappConnectionLog[]
  whatsappWebhookLogs WhatsappWebhookLog[]

  // Novos modelos para automação de agência
  serviceCatalog     ServiceCatalog[]
  deliverables       Deliverable[]
  timeEntries        TimeEntry[]
  knowledgeBase      KnowledgeBase[]
  clientHealthScores ClientHealthScore[]

  // SaaS Control (Super Admin -> Agency)
  saasInvoices      SaaSInvoice[]
  supportTickets    SupportTicket[]

  // Nexus Prospect AI
  prospectMissions  ProspectMission[]

  // Autonomus CRM: verticalização por tipo de negócio
  businessType        String?  // B2B, B2C, SaaS, Consultoria, Indústria, E-commerce, Varejo, etc.
  businessDescription String?  // Descrição livre do que o cliente vende

  onboardingResponse OnboardingResponse?
  organizationExperience OrganizationExperience?
  organizationModules OrganizationModule[]
  provisioningRuns ProvisioningRun[]

  customFields          CustomField[]
  lostReasons           LostReason[]
  wonReasons            WonReason[]
  npsSurveys            NpsSurvey[]
  renewalOpportunities  RenewalOpportunity[]
  aiLogs                AiLog[]

  // ACP v2.0
  acpAccesses           AcpAccess[]
  googleLocalAccesses   GoogleLocalAccess[]
  googleLocalProfiles   GoogleLocalProfile[]
  googleLocalScans      GoogleLocalScan[]
  acpDiagnoses          AcpDiagnosis[]
  acpIcps               AcpIcp[]
  acpOffers             AcpOffer[]
  acpAgentExecutions    AcpAgentExecution[]
  acpObjections         AcpObjection[]
  acpCompetitors        AcpCompetitor[]
  acpQuarterlyPlans     AcpQuarterlyPlan[]
  acpChurnSignals       AcpChurnSignal[]
  agentQueueItems        AgentQueueItem[]

  // Whitelabel Sync Logs (Fase 3)
  whitelabelSyncLogs WhitelabelSyncLog[]

  // Qualificação de Leads
  qualificationForms       QualificationForm[]
  qualificationSubmissions QualificationSubmission[]

  // Onboarding: Experiências Profissionais
  professionalExperiences ProfessionalExperience[]
}

model Workspace {
  id             String       @id @default(uuid())
  name           String
  slug           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  settings       Json?
  isActive       Boolean      @default(true)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users          User[]
  leads          Lead[]

  @@unique([organizationId, slug])
}

model AgencyPlan {
  id        String   @id @default(uuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  name      String
  price     Float
  limits    Json
  features  Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique @default("free")
  description  String?
  priceMonthly Float?
  priceYearly  Float?
  isPublic     Boolean  @default(true)
  isActive     Boolean  @default(true)
  
  // Limites Base
  maxUsers        Int      @default(1)
  maxContacts     Int      @default(100)
  maxDeals        Int      @default(50)
  maxPipelines    Int      @default(1)
  maxAutomations  Int      @default(2)
  maxLandingPages Int      @default(1)
  maxInboxes      Int      @default(1)
  maxMessages     Int      @default(500)
  maxAIRequests   Int      @default(10) // Créditos de IA
  maxLeads        Int      @default(100)
  maxClients      Int      @default(10)
  maxReports      Int      @default(5)
  maxIntegrations Int      @default(2)
  
  // Features Disponíveis (JSON para flexibilidade ou booleanos)
  features        Json?    // Ex: { "whiteLabel": false, "apiAccess": false }
  
  organizations Organization[]
  subscriptions SaaSSubscription[]
  planFeatures  PlanFeature[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Module {
  id          String    @id @default(uuid())
  key         String    @unique // dashboard, crm, landing_pages, etc.
  name        String
  description String?
  category    String?
  isActive    Boolean   @default(true)
  features    Feature[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Feature {
  id          String        @id @default(uuid())
  moduleKey   String
  module      Module        @relation(fields: [moduleKey], references: [key])
  key         String        @unique // crm.export, ai.sdr, etc.
  name        String
  description String?
  isActive    Boolean       @default(true)
  planFeatures PlanFeature[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PlanFeature {
  id         String  @id @default(uuid())
  planId     String
  plan       Plan    @relation(fields: [planId], references: [id])
  featureKey String
  feature    Feature @relation(fields: [featureKey], references: [key])
  isEnabled  Boolean @default(true)
  limit      Int?    // Limite específico para esta feature (ex: 2 agentes de IA)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, featureKey])
}

model Role {
  id             String           @id @default(uuid())
  organizationId String?          // Se null, é uma role global (sistema)
  name           String
  key            String           // owner, admin, manager, member, guest
  scope          String           @default("AGENCY") // PLATFORM, AGENCY, CLIENT
  isSystem       Boolean          @default(false)
  permissions    RolePermission[]
  users          User[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  @@unique([organizationId, key])
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique // leads.create, finance.view, etc.
  name        String
  description String?
  moduleKey   String?
  roles       RolePermission[]
  users       UserPermission[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionKey String
  permission   Permission @relation(fields: [permissionKey], references: [key])
  isAllowed    Boolean    @default(true)

  @@unique([roleId, permissionKey])
}

model UserPermission {
  id             String     @id @default(uuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  organizationId String
  permissionKey  String
  permission     Permission @relation(fields: [permissionKey], references: [key])
  isAllowed      Boolean    @default(true)

  @@unique([userId, organizationId, permissionKey])
}

model AuditLog {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  action         String        // CREATE, UPDATE, DELETE, LOGIN, EXPORT
  resource       String        // Lead, Client, Campaign
  resourceId     String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime      @default(now())

  @@index([organizationId])
  @@index([userId])
}

model Snapshot {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  data           Json         // Objeto serializado com pipelines, etapas, etc.
  isPublic       Boolean      @default(false)
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SystemSettings {
  id                String   @id @default("global")
  crmPublic         Boolean  @default(false)
  salesMachinePublic Boolean @default(false)
  agentBuilderPublic Boolean @default(false)
  updatedAt         DateTime @updatedAt
}

model SaaSSubscription {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  planId          String?
  plan            Plan?        @relation(fields: [planId], references: [id])
  status          String       @default("TRIAL") // TRIAL, ACTIVE, PAST_DUE, SUSPENDED, CANCELED, EXPIRED
  startDate       DateTime     @default(now())
  endDate         DateTime?
  trialEndsAt     DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd DateTime?
  price           Float?
  billingCycle    String?      // MONTHLY, YEARLY
  provider        String?      // Stripe, Asaas, etc.
  providerSubId   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
}

model SaaSInvoice {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  amount         Float
  dueDate        DateTime
  paidAt         DateTime?
  status         String       @default("PENDING") // PENDING, PAID, CANCELLED
  invoiceUrl     String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model SupportTicket {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  subject        String
  description    String       @db.Text
  status         String       @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority       String       @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  category       String // BILLING, TECHNICAL, BUG, FEATURE
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String
  role     String  @default("USER") // SUPER_ADMIN, AGENCY_ADMIN, ORG_ADMIN, USER
  status   String  @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED

  avatarUrl String?

  agencyId       String?
  agency         Agency?       @relation(fields: [agencyId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  workspaceId    String?
  workspace      Workspace?    @relation(fields: [workspaceId], references: [id])

  managedLeads         Lead[]
  assignedTasks        Task[]
  managedClients       Client[]
  managedOpportunities Opportunity[]
  followUps            FollowUp[]
  department           String?       @default("GERAL") // BDR, SDR, CLOSER, etc
  calendarEvents       CalendarEvent[]
  leadCaptureSources   LeadCaptureSource[]
  leadCaptureUsageLogs LeadCaptureUsageLog[]
  permissions Json? // Ex: { "leads": ["view", "edit"], "crm": ["manage_boards"] }
  
  accessProfileId      String?
  accessProfile        AccessProfile? @relation(fields: [accessProfileId], references: [id])
  
  roleId               String?
  roleObj              Role?          @relation(fields: [roleId], references: [id])
  userPermissions      UserPermission[]
  googleLocalAccesses  GoogleLocalAccess[] @relation("GoogleLocalAccessUser")
  googleLocalGrants    GoogleLocalAccess[] @relation("GoogleLocalAccessGrantedBy")
  googleLocalProfiles  GoogleLocalProfile[] @relation("GoogleLocalProfileCreatedBy")
  googleLocalScans     GoogleLocalScan[] @relation("GoogleLocalScanCreatedBy")
  
  conversations        Conversation[]
  refreshTokens        RefreshToken[]
  
  // Nexus Prospect AI
  prospectMissions       ProspectMission[]
  prospectMissionsOwned  ProspectMission[] @relation("MissionSalesOwner")
  
  professionalExperiences ProfessionalExperience[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([organizationId])
  @@index([agencyId])
  @@index([workspaceId])
}

model AccessProfile {
  id             String       @id @default(uuid())
  name           String
  description    String?
  permissions    Json
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  users          User[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Lead {
  id     String  @id @default(uuid())
  name   String
  email  String
  phone  String?
  whatsapp String?
  cpf    String?
  jobTitle String?
  
  birthDate DateTime?
  status   String  @default("novo") // qualificado, desqualificado, etc.
  value    Float   @default(0)
  tags     String?
  source   String?
  channel  String?
  notes    String? @db.Text
  cnpj     String?
  owners   String? @db.Text
  managementTeam String? @db.Text
  aiDiagnosis    String? @db.Text

  temperature String  @default("COLD") // COLD, WARM, HOT
  score       Int     @default(0)
  
  lgpdConsent Boolean @default(false)
  lgpdDate    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  workspaceId    String?
  workspace      Workspace?    @relation(fields: [workspaceId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  clientId String? // Empresa vinculada
  client   Client? @relation(fields: [clientId], references: [id])

  pipelineId String?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id])
  stageId    String?
  stage      PipelineStage? @relation(fields: [stageId], references: [id])

  followUps       FollowUp[]
  quizSubmissions QuizSubmission[]
  proposals       Proposal[]
  conversations   Conversation[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([assignedToId])
  @@index([workspaceId])
}

model FollowUp {
  id          String    @id @default(uuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id])
  type        String
  content     String
  status      String    @default("pending")
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
}

model Creative {
  id         String  @id @default(uuid())
  title      String
  type       String // image, video, copy, carousel
  contentUrl String? // Link to file
  copyText   String?
  status     String  @default("pending") // pending, approved, rejected, revision
  feedback   String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Project {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("planejamento")
  deadline    DateTime?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  tasks Task[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Client {
  id            String  @id @default(uuid())
  corporateName String // Razão Social
  tradeName     String? // Nome Fantasia
  cnpj          String? @unique
  cpf           String?
  email         String
  phone         String?
  website       String?

  // Endereço
  address String?
  city    String?
  state   String?
  zipCode String?

  // Dados Business
  segment   String? // Segmento: Tech, Saúde, Retail, etc
  porte     String? // Porte: MEI, Pequeno, Médio, Grande
  employees Int?
  revenue   Float?

  // Dados do Responsável
  responsibleName  String?
  responsibleCpf   String?
  responsibleEmail String?
  responsiblePhone String?
  responsibleRole  String?

  // Status
  status String @default("prospect") // prospect, onboarding, ativo, inativo, churned
  renewalDate DateTime?
  churnRisk   String   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  lastNpsScore Int?

  // Origem (Raio-X)
  source       String? // Google Ads, Instagram, Indicação, Prospecção Ativa
  sourceDetail String? // Ex: Campanha X, Nome de quem indicou

  // Portal do Cliente
  portalAccess Boolean @default(false)
  password     String?

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  opportunities Opportunity[]
  proposals     Proposal[]
  invoices      Invoice[]
  contracts     Contract[]
  soldProducts  SoldProduct[]
  demands       Demand[]
  projects      Project[]
  leads         Lead[]
  npsSurveys            NpsSurvey[]
  renewalOpportunities  RenewalOpportunity[]

  notes String?
  tags  String?

  // AI Context & History
  aiContext        ClientAIContext?
  aiGenerations    AIGeneration[]
  generatedPrompts GeneratedPrompt[]
  agentQueueItems  AgentQueueItem[]
  adAccounts       AdAccount[]
  adMetricSnapshots AdMetricSnapshot[]
  adsInsights      AdsInsight[]
  adsRecommendations AdsRecommendation[]
  reportShares     ClientReportShare[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([assignedToId])
}

model ClientAIContext {
  id       String @id @default(uuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  context Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIGeneration {
  id       String @id @default(uuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  campaignId String?
  agentType  String

  prompt   String
  response String

  createdAt DateTime @default(now())
}

model AgentQueueItem {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  agentId        String
  agentName      String
  phase          String?
  category       String?
  autonomy       String       @default("semi_autonomo")
  actionType     String
  title          String
  description    String?      @db.Text
  input          Json?
  output         Json?
  result         Json?
  status         String       @default("queued") // queued, running, completed, failed, needs_approval, skipped
  priority       Int          @default(50)
  attempts       Int          @default(0)
  maxAttempts    Int          @default(3)
  dependsOnId    String?
  lockedAt       DateTime?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  error          String?      @db.Text
  metadata       Json?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([agentId])
  @@index([scheduledAt])
}

model Opportunity {
  id          String  @id @default(uuid())
  title       String
  description String?

  // Pipeline context
  pipelineId  String?
  pipeline    Pipeline? @relation(fields: [pipelineId], references: [id])
  stageId     String?
  stageObj    PipelineStage? @relation(fields: [stageId], references: [id])
  
  stage       String @default("qualificacao") // Legacy / fallback
  probability Int    @default(10)

  value          Float  @default(0)
  estimatedValue Float?

  expectedCloseDate DateTime?
  closedAt          DateTime?

  status      String  @default("OPEN") // OPEN, WON, LOST, FROZEN
  lostReason  String?
  lostReasonId String?
  wonReasonId  String?
  
  temperature String  @default("COLD") // COLD, WARM, HOT
  score       Int     @default(0)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  nextActionAt      DateTime?
  lastInteractionAt DateTime?
  
  objections  Json?
  customFields Json?

  tasks       Task[]
  proposals   Proposal[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([assignedToId])
  @@index([pipelineId])
  @@index([stageId])
}

model Proposal {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  status          String   @default("draft")
  
  clientId        String?
  client          Client?  @relation(fields: [clientId], references: [id])
  
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id])
  
  opportunityId   String?
  opportunity     Opportunity? @relation(fields: [opportunityId], references: [id])
  
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  logoUrl         String?
  footerText      String?
  
  content         Json     
  items           ProposalItem[]
  statusHistory   ProposalStatusHistory[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([slug])
}

model ProposalItem {
  id         String   @id @default(uuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id])

  service     String
  description String?
