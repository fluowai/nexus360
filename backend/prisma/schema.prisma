// ==================== WEBHOOKS E API ====================

model Webhook {
  id             String         @id @default(uuid())
  organizationId String
  url            String
  secret         String?
  events         Json           // Array de eventos: ["contact.created", "deal.won", ...]
  isActive       Boolean        @default(true)
  failCount      Int            @default(0)
  lastTriggeredAt DateTime?
  
