# =========================================================================
#                    NEXUS360 - ENVIRONMENT VARIABLES EXAMPLE
# =========================================================================
# Copy this file to a new file named '.env' at the root or within specific
# directories (backend/.env, frontend/.env) to configure the application.
# For Portainer Stacks, configure these variables in the stack environment settings.

# -----------------
# 1. CORE API & SERVICES KEYS
# -----------------
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GROQ_API_KEY="MY_GROQ_API_KEY"
SERPER_API_KEY="MY_SERPER_API_KEY"
SERPAPI_API_KEY="MY_SERPAPI_API_KEY"
OUTSCRAPER_API_KEY="MY_OUTSCRAPER_API_KEY"
MUAC_API_KEY="MY_MUAC_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# -----------------
# 2. BACKEND DATABASE & SYSTEM CONFIG (backend/.env)
# -----------------
# Database connection strings (PostgreSQL / Supabase)
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexus360_db?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/nexus360_db?schema=public"

# Authentication Security (Must be a secure 256-bit random string in production)
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARS"

# CORS & Server Environment
FRONTEND_URL="http://localhost:8080"
NODE_ENV="production"
PORT=10000

# White label / custom domains for Docker + Traefik
# Set this to the public IP clients must use in their DNS A record.
WHITELABEL_DOCKER_IP="207.58.153.219"
WHITELABEL_CNAME_TARGET="nexus360.consultio.com.br"
# Modo de sincronia: "file" (recomendado) ou "docker-service"
TRAEFIK_SYNC_MODE="file"
TRAEFIK_ROUTER_SERVICE="nexus360_frontend"
TRAEFIK_ROUTER_LABEL_PREFIX="nexus360_custom"
TRAEFIK_DOCKER_NETWORK="consultio1"
DOCKER_SOCKET_PATH="/var/run/docker.sock"
TRAEFIK_DYNAMIC_DIR="/traefik/dynamic"
TRAEFIK_FRONTEND_URL="http://nexus360_frontend:80"
TRAEFIK_API_URL="http://nexus360_api:10000"
TRAEFIK_CERT_RESOLVER="letsencryptresolver"

# -----------------
# 3. EXTERNAL INTEGRATIONS (Optional / Feature specific)
# -----------------
# CNPJ Data Processing (Receita Federal WebDAV)
CNPJ_WEBDAV_TOKEN="your-webdav-share-token"

# LiveKit WebRTC Configuration (For audio/video communication and rooms)
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-api-secret"
LIVEKIT_URL="wss://your-livekit-server.cloud"

# WhatsApp / Whatsmeow bridge
WHATSAPP_BRIDGE_URL="http://localhost:8091"
WHATSAPP_BRIDGE_PUBLIC_URL="http://localhost:8091"
WHATSAPP_BRIDGE_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
NEXUS_BACKEND_URL="http://localhost:10000"

# -----------------
# 4. FRONTEND BUILD TIME CONFIG (frontend/.env or frontend/.env.production)
# -----------------
# Vite API routing and LiveKit client endpoints
VITE_API_URL="http://localhost:10000"
VITE_LIVEKIT_URL="wss://your-livekit-server.cloud"
