# Nexus360 - variaveis para Portainer Stack
#
# Copie estes pares para Environment variables da Stack no Portainer.
# Em producao, troque obrigatoriamente DATABASE_URL, DIRECT_URL, JWT_SECRET
# e SEED_ADMIN_PASSWORD. Nao versione secrets reais.

# === DATABASE ===
DATABASE_URL=postgresql://postgres.projeto:senha@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&statement_cache_size=0
DIRECT_URL=postgresql://postgres:senha@db.projeto.supabase.co:5432/postgres?sslmode=require&schema=public
PGSSLMODE=require

# === AUTH ===
JWT_SECRET=troque_por_um_segredo_longo_com_32_chars_ou_mais
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === URLS ===
FRONTEND_URL=https://nexus360.consultio.com.br
CORS_ORIGINS=https://nexus360.consultio.com.br,https://www.nexus360.consultio.com.br

# === WHITELABEL / DOMINIOS PERSONALIZADOS ===
# IP do servidor para registro A
WHITELABEL_DOCKER_IP=207.58.153.219
# Alvo CNAME (opcional)
WHITELABEL_CNAME_TARGET=nexus360.consultio.com.br

# === TRAEFIK ===
# Modo recomendado: "docker-service". O modo "file" exige volume compartilhado e provider file no Traefik.
TRAEFIK_SYNC_MODE=docker-service
TRAEFIK_DYNAMIC_DIR=/traefik/dynamic
TRAEFIK_FRONTEND_URL=http://nexus360_frontend:80
TRAEFIK_API_URL=http://nexus360_api:10000
TRAEFIK_CERT_RESOLVER=letsencryptresolver
TRAEFIK_ROUTER_SERVICE=nexus360_frontend
TRAEFIK_ROUTER_LABEL_PREFIX=nexus360_custom
TRAEFIK_DOCKER_NETWORK=consultio1

# === FRONTEND (build-time - configurado no CI) ===
VITE_API_URL=same-origin
VITE_LIVEKIT_URL=

# === AI KEYS ===
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
CHATGPT_API_KEY=
AI_CORE_URL=http://litellm:4000/v1
AI_CORE_API_KEY=
AI_CORE_DEFAULT_MODEL=gpt-4o-mini
LITELLM_MASTER_KEY=
SERPER_API_KEY=
SERPAPI_API_KEY=
SERP_API_KEY=
OUTSCRAPER_API_KEY=
OUTSCRAPER_KEY=
MUAC_API_KEY=
TOGETHER_API_KEY=

# === LIVEKIT ===
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# === BILLING ===
BILLING_WEBHOOK_SECRET=
ASAAS_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=

# === WHATSAPP ===
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:8091
WHATSAPP_BRIDGE_PUBLIC_URL=https://seu-dominio-ou-subdominio-do-bridge
WHATSAPP_BRIDGE_SECRET=troque_por_um_segredo_longo_para_o_bridge
NEXUS_BACKEND_URL=http://backend:10000
