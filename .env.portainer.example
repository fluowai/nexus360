# Nexus360 - variaveis para Portainer Stack
#
# Copie estes pares para Environment variables da Stack no Portainer.
# Em producao, troque obrigatoriamente DATABASE_URL, DIRECT_URL, JWT_SECRET
# e SEED_ADMIN_PASSWORD. Nao versione secrets reais.

DATABASE_URL=postgresql://usuario:senha@host:5432/postgres?sslmode=require&schema=public
DIRECT_URL=postgresql://usuario:senha@host:5432/postgres?sslmode=require&schema=public
PGSSLMODE=require

JWT_SECRET=troque_por_um_segredo_longo_com_32_chars_ou_mais
FRONTEND_URL=https://nexus360.consultio.com.br
CORS_ORIGINS=https://nexus360.consultio.com.br,https://www.nexus360.consultio.com.br
SEED_ADMIN_EMAIL=admin@nexus360.com
SEED_ADMIN_PASSWORD=troque_por_uma_senha_forte
RUN_DB_PUSH=true
RUN_SEED=true

VITE_API_URL=same-origin
VITE_LIVEKIT_URL=

GEMINI_API_KEY=
GROQ_API_KEY=
SERPER_API_KEY=
SERPAPI_API_KEY=
SERP_API_KEY=
OUTSCRAPER_API_KEY=
OUTSCRAPER_KEY=
MUAC_API_KEY=
TOGETHER_API_KEY=

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

VERCEL_API_TOKEN=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

DIRECT_ADMIN_URL=
DIRECT_ADMIN_USER=
DIRECT_ADMIN_API_KEY=
WHM_MAIN_DOMAIN=consultio.com.br

BILLING_WEBHOOK_SECRET=
ASAAS_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=
