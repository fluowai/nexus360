// Nexus360 CRM 360 - Schema Completo para Agência de Geração de Leads

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Organization {
  id          String   @id @default(uuid())
  name        String
  domain      String?  @unique
  plan        String   @default("Free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  leads       Lead[]
  projects    Project[]
  clients     Client[]
  opportunities Opportunity[]
  proposals   Proposal[]
  campaigns   Campaign[]
  tasks       Task[]
  invoices    Invoice[]
  contracts   Contract[]
  sequences   Sequence[]
  creatives   Creative[]
  products    Product[]
  expenses   Expense[]
  notifications Notification[]
  calendarEvents CalendarEvent[]
  adAccounts   AdAccount[]
  assets      Asset[]
  assetFolders AssetFolder[]
  landingPages LandingPage[]
  quizzes     Quiz[]
  automations Automation[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String?
  password       String
  role           String       @default("USER") // SUPER_ADMIN, ORG_ADMIN, USER
  status         String       @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED

  avatarUrl      String?
  
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  managedLeads   Lead[]
  assignedTasks  Task[]
  managedClients Client[]
  managedOpportunities Opportunity[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Lead {
  id             String       @id @default(uuid())
  name           String
  email          String
  phone          String?
  status         String       @default("novo")
  value          Float        @default(0)
  tags           String?      
  source         String?
  notes          String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  followUps      FollowUp[]
  quizSubmissions QuizSubmission[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model FollowUp {
  id             String       @id @default(uuid())
  leadId         String
  lead           Lead         @relation(fields: [leadId], references: [id])
  type           String
  content        String
  status         String       @default("pending")
  scheduledAt    DateTime?
  createdAt      DateTime     @default(now())
}

model Creative {
  id             String       @id @default(uuid())
  title          String
  type           String       // image, video, copy, carousel
  contentUrl     String?      // Link to file
  copyText       String?      
  status         String       @default("pending") // pending, approved, rejected, revision
  feedback       String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  campaignId     String?
  campaign       Campaign?     @relation(fields: [campaignId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Project {
  id             String       @id @default(uuid())
  title          String
  description    String?
  status         String       @default("planejamento")
  deadline       DateTime?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ============ NOVOS MODELOS CRM 360 ============

model Client {
  id             String       @id @default(uuid())
  corporateName  String       // Razão Social
  tradeName      String?      // Nome Fantasia
  cnpj           String?      @unique
  cpf            String?
  email          String
  phone          String?
  website        String?
  
  // Endereço
  address        String?
  city           String?
  state          String?
  zipCode        String?
  
  // Dados Business
  segment        String?      // Segmento: Tech, Saúde, Retail, etc
  porte          String?      // Porte: MEI, Pequeno, Médio, Grande
  employees      Int?
  revenue        Float?
  
  // Status
  status         String       @default("prospect") // prospect, ativo, inativo, churned
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  opportunities  Opportunity[]
  proposals      Proposal[]
  invoices       Invoice[]
  contracts      Contract[]
  
  notes          String?
  tags           String?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Opportunity {
  id             String       @id @default(uuid())
  title          String
  description    String?
  
  // Funil
  stage          String       @default("qualificacao") // qualificacao, proposta, negociacao, fechado_ganho, fechado_perdido
  probability    Int          @default(10) // Porcentagem
  
  // Valores
  value          Float        @default(0)
  estimatedValue Float?       // Valor estimado se fechado
  
  // Datas
  expectedCloseDate DateTime?
  closedAt        DateTime?
  
  // Motivo perda
  lostReason     String?
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Proposal {
  id             String       @id @default(uuid())
  title          String
  description    String?
  
  // Status
  status         String       @default("rascunho") // rascunho, enviada, aceita, rejeitada, expirada
  
  // Valores
  subtotal       Float        @default(0)
  discount       Float        @default(0)
  total          Float        @default(0)
  
  // Datas
  sentAt         DateTime?
  expiresAt      DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  
  // Itens
  items          ProposalItem[]
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ProposalItem {
  id             String       @id @default(uuid())
  proposalId     String
  proposal       Proposal     @relation(fields: [proposalId], references: [id])
  
  service        String       // Nome do serviço
  description    String?
  quantity       Int          @default(1)
  unitPrice      Float        @default(0)
  total          Float        @default(0)
  
  order          Int          @default(0)
}

model Campaign {
  id             String       @id @default(uuid())
  name           String
  description    String?
  
  // Tipo
  type           String       // facebook, google, instagram, linkedin, email, whatsapp
  
  // Status
  status         String       @default("ativa") // rascunho, ativa, pausada, encerrada
  
  // Datas
  startDate      DateTime?
  endDate        DateTime?
  
  // Orçamento e ROI
  budget         Float        @default(0)
  spent          Float        @default(0)
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  leadsGenerated Int          @default(0)
  conversions    Int          @default(0)
  revenue        Float        @default(0)
  
  // UTM
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  creatives      Creative[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  
  // Status
  status         String       @default("pendente") // pendente, em_andamento, concluida, cancelada
  
  // Prioridade
  priority       String       @default("media") // baixa, media, alta, urgente
  
  // Datas
  dueDate        DateTime?
  completedAt    DateTime?
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  assignedToId   String?
  assignedTo     User?         @relation(fields: [assignedToId], references: [id])
  
  // Relacionar a Lead, Oportunidade ou Proposta
  leadId         String?
  opportunityId  String?
  proposalId     String?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Invoice {
  id             String       @id @default(uuid())
  invoiceNumber  String       @unique // Numero da fatura
  
  // Status
  status         String       @default("pendente") // pendente, paga, vencida, cancelada
  
  // Datas
  issueDate      DateTime     @default(now())
  dueDate        DateTime
  paidAt         DateTime?
  
  // Valores
  subtotal       Float        @default(0)
  discount       Float        @default(0)
  tax            Float        @default(0)
  total          Float        @default(0)
  
  // Descrição
  description    String?
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  
  contractId     String?
  contract       Contract?     @relation(fields: [contractId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Contract {
  id             String       @id @default(uuid())
  title          String
  contractNumber String       @unique
  
  // Status
  status         String       @default("rascunho") // rascunho, ativo, expirado, cancelado
  
  // Datas
  startDate      DateTime
  endDate        DateTime?
  renewedAt      DateTime?
  
  // Valores
  value          Float        @default(0)
  billingCycle   String       @default("mensal") // mensal, bimestral, trimestral, anual
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  
  invoices       Invoice[]
  
  notes          String?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Sequence {
  id             String       @id @default(uuid())
  name           String
  description    String?
  
  // Status
  isActive       Boolean      @default(true)
  
  // Trigger
  triggerType    String       // lead_status_change, manual, form_submit
  
  // Passos
  steps          SequenceStep[]
  
  // Relations
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SequenceStep {
  id             String       @id @default(uuid())
  sequenceId     String
  sequence       Sequence     @relation(fields: [sequenceId], references: [id])
  
  order          Int
  type           String       // email, whatsapp, wait, task
  
  // Configuração do passo
  subject        String?      // Para email
  body           String?      // Conteúdo
  waitDays       Int?         // Dias de espera
  
  // Conditions
  condition      String?
  
  createdAt      DateTime     @default(now())
}

// ============ NOVOS MODELOS ERP COMPLETO ============

model Product {
  id             String       @id @default(uuid())
  name           String
  description     String?
  sku            String?      @unique
  category       String?      // Servicio, Produto, Insumo
  unitPrice      Float        @default(0)
  unit           String?      // hora, un, mes
  
  // Controle de estoque
  stock          Int         @default(0)
  minStock       Int         @default(0)
  
  isActive       Boolean      @default(true)
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Expense {
  id             String       @id @default(uuid())
  description    String
  amount         Float
  category       String      // operacional, marketing, pessoal, infraestrutura, outros
  date          DateTime     @default(now())
  status         String      @default("pendente") // pendente, paga
  paidAt        DateTime?
  
  // Origem
  supplier       String?      // Fornecedor
  document      String?      // NF, Recibo
  
  isRecurring   Boolean     @default(false)
  recurringType String?     // mensal, trimestral, anual
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Notification {
  id             String       @id @default(uuid())
  title          String
  message        String
  type           String       @default("info") // info, success, warning, error
  isRead         Boolean      @default(false)
  link          String?      // Link para navegacao
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
}

model CalendarEvent {
  id             String       @id @default(uuid())
  title          String
  description    String?
  startDate      DateTime
  endDate       DateTime?
  allDay        Boolean     @default(false)
  
  // Tipo
  type           String       // reunion, task, deadline, birthday, holiday
  
  // Status
  status         String      @default("scheduled") // scheduled, completed, cancelled
  
  // Lembrete
  reminder      Int?        // minutos antes
  
  // Relations
  leadId         String?
  taskId        String?
  projectId     String?
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  meetingRoom    String?
  meetingLink    String?
  
  createdAt      DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}


// ============ GESTÃO DE CONTAS DE ANÚNCIO ============

model AdAccount {
  id              String        @id @default(uuid())
  accountId        String        // ID real da plataforma (ex: act_123456)
  accountName     String
  platform        String        // meta, google, linkedin, tiktok
  accountStatus  String       @default("active")
  
  accessToken    String?
  refreshToken   String?
  tokenExpiry    DateTime?
  
  accountCurrency String?
  accountTimezone String?
  
  dailySpendLimit Float      @default(0)
  currentSpend   Float      @default(0)
  
  organizationId  String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  campaigns      CampaignAd[]
  creatives     AdCreative[]
  audiences     CustomAudience[]
}

model CampaignAd {
  id             String       @id @default(uuid())
  campaignId     String
  name           String
  
  platform       String
  objective      String
  
  status        String        @default("paused")
  biddingStrategy String      @default("lowest_cost")
  
  startDate     DateTime?
  endDate       DateTime?
  
  budgetType    String       @default("daily")
  budgetAmount  Float       @default(0)
  spendAmount   Float       @default(0)
  
  locations    String?
  ageMin        Int          @default(18)
  ageMax        Int          @default(65)
  genders      String?
  interests    String?
  
  pixelId      String?
  conversionEvent String?
  
  adAccountId  String
  adAccount   AdAccount    @relation(fields: [adAccountId], references: [id])
  
  adSets       AdSet[]
  
  createdAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AdSet {
  id            String       @id @default(uuid())
  adSetId       String
  name          String
  
  status        String        @default("active")
  targeting     String?
  
  budgetType   String       @default("daily")
  budgetAmount Float       @default(0)
  
  campaignAdId String
  campaignAd  CampaignAd  @relation(fields: [campaignAdId], references: [id])
  
  ads         Ad[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Ad {
  id            String       @id @default(uuid())
  adId          String
  name          String
  
  status        String        @default("active")
  format        String        // image, video, carousel, collection
  
  creativeId    String?
  creative     AdCreative?   @relation(fields: [creativeId], references: [id])
  
  adSetId      String
  adSet        AdSet        @relation(fields: [adSetId], references: [id])
  
  impressions  Int          @default(0)
  clicks       Int          @default(0)
  spend        Float        @default(0)
  conversions  Int          @default(0)
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AdCreative {
  id            String       @id @default(uuid())
  name          String
  
  type          String      // image, video, carousel, collection, story
  
  imageUrl      String?
  videoUrl     String?
  thumbnailUrl String?
  
  headline     String?
  primaryText  String?
  description String?
  callToAction String?
  
  displayLink  String?
  destinationUrl String?
  
  platformData String?
  
  adAccountId  String
  adAccount   AdAccount    @relation(fields: [adAccountId], references: [id])
  
  ads         Ad[]
  
  createdAt   DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model CustomAudience {
  id             String       @id @default(uuid())
  audienceId     String
  name          String
  platform      String       // meta, google
  description   String?
  
  audienceType  String       // custom, lookalike, interest
  
  rule         String?
  sourceAudience String?
  
  size         Int          @default(0)
  
  adAccountId  String
  adAccount  AdAccount    @relation(fields: [adAccountId], references: [id])
  
  createdAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ============ BIBLIOTECA DE ASSETS ============

model Asset {
  id            String       @id @default(uuid())
  name          String
  type          String       // image, video, audio, document, template
  mimeType      String?
  size          Int?
  
  url           String?
  thumbnailUrl  String?
  
  width         Int?
  height        Int?
  duration      Int?
  tags          String?
  
  folderId      String?
  folder       AssetFolder?  @relation(fields: [folderId], references: [id])
  
  usedIn        String?
  
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt     DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model AssetFolder {
  id             String       @id @default(uuid())
  name           String
  parentId       String?
  parent         AssetFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children       AssetFolder[] @relation("FolderHierarchy")
  
  assets        Asset[]
  
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt     DateTime     @default(now())
}

// ============ LANDING PAGES ============

model LandingPage {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  
  templateId     String?
  template       LPTemplate?   @relation(fields: [templateId], references: [id])
  
  headline       String?
  subheadline    String?
  heroImage      String?
  heroVideo     String?
  content        String?      // JSON sections
  
  formId          String?
  form           LPForm?      @relation(fields: [formId], references: [id])
  formProvider   String?      // native, meta, google
  formConfig     String?      // JSON
  
  status         String       @default("draft")
  
  views          Int          @default(0)
  submissions   Int          @default(0)
  conversionRate Float       @default(0)
  
  domain         String?
  customDomain  String?
  
  metaTitle     String?
  metaDescription String?
  metaImage    String?
  
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model LPTemplate {
  id            String        @id @default(uuid())
  name          String
  category      String        // lead_gen, webinar, ebook, product
  
  thumbnail     String?
  htmlTemplate  String?
  
  isActive      Boolean       @default(true)
  isPro         Boolean       @default(false)
  
  landingPages  LandingPage[]
  
  createdAt  DateTime     @default(now())
}

model LPForm {
  id              String        @id @default(uuid())
  name            String
  
  fields          String       // JSON
  
  submitAction    String       // url, webhook, email
  submitUrl       String?
  webhookUrl      String?
  emailTo         String?
  emailSubject    String?
  
  autoReply       Boolean      @default(false)
  replySubject    String?
  replyMessage   String?
  
  gdprConsent    Boolean      @default(false)
  gdprText       String?
  
  landingPages   LandingPage[]
  
  createdAt      DateTime     @default(now())
}

// ============ QUIZ / LEAD QUALIFIER ============

model Quiz {
  id             String       @id @default(uuid())
  name           String
  description    String?
  
  quizType       String       // qualification, assessment, recommendation
  
  isActive       Boolean      @default(true)
  isProspectOnly Boolean     @default(false)
  
  scoringType    String       // binary, points, segments
  passScore     Int?
  
  resultsConfig String?
  
  questions    QuizQuestion[]
  submissions QuizSubmission[]
  
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model QuizQuestion {
  id              String       @id @default(uuid())
  questionText   String
  
  questionType  String       // multiple_choice, multiple_select, rating, text, email, phone
  
  options       String?
  
  isRequired    Boolean      @default(true)
  order        Int
  
  points       Int          @default(1)
  
  quizId        String
  quiz         Quiz         @relation(fields: [quizId], references: [id])
  
  createdAt   DateTime     @default(now())
}

model QuizSubmission {
  id             String       @id @default(uuid())
  
  answers        String
  score          Int?
  segment        String?
  
  leadId         String?
  lead           Lead?       @relation(fields: [leadId], references: [id])
  
  contactName   String?
  contactEmail  String?
  contactPhone String?
  
  quizId        String
  quiz          Quiz         @relation(fields: [quizId], references: [id])
  
  createdAt    DateTime     @default(now())
}

// ============ AUTOMATION ============

model Automation {
  id             String       @id @default(uuid())
  name           String
  description    String?
  
  triggerType   String       // form_submission, quiz_completion, lead_score, manual
  triggerConfig String?
  
  conditions    String?
  actions       String?
  
  isActive      Boolean       @default(true)
  
  executions   Int           @default(0)
  lastExecution DateTime?
  
  organizationId String
  organization  Organization  @relation(fields: [organizationId], references: [id])
  
  createdAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}