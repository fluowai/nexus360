// ==================== OMNICHANNEL ====================

model Inbox {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  channels       Channel[]
  conversations  Conversation[]
  sla            InboxSla?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Channel {
  id             String       @id @default(uuid())
  type           String       // WHATSAPP, INSTAGRAM, MESSENGER, WEBCHAT, EMAIL
  provider       String       // WOOAPI, META, SMTP
  identifier     String       // Número de telefone, email, etc.
  config         Json?
  
  inboxId        String
  inbox          Inbox        @relation(fields: [inboxId], references: [id])
  
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversations  Conversation[]
  dispatchAttempts ProspectingDispatchAttempt[]
  whatsappContactIdentities WhatsappContactIdentity[]
  whatsappGroupParticipants WhatsappGroupParticipant[]
  whatsappConnectionLogs WhatsappConnectionLog[]
}

model Conversation {
  id             String       @id @default(uuid())
  subject        String?
  status         String       @default("open") // open, pending, closed, snoozed
  priority       String       @default("medium")
  
  inboxId        String
  inbox          Inbox        @relation(fields: [inboxId], references: [id])
  
  channelId      String
  channel        Channel      @relation(fields: [channelId], references: [id])
  
  contactId      String?      // Relacionado ao Lead ou Cliente (será unificado no futuro se necessário)
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  
  assignedToId   String?
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  
  messages       Message[]
  whatsappContactIdentity WhatsappContactIdentity?
  groupParticipants WhatsappGroupParticipant[]
  lastMessageAt  DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([inboxId])
  @@index([channelId])
  @@index([leadId])
  @@index([status])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  
  senderId       String?      // Se for usuário interno
  senderType     String       // USER, CONTACT, SYSTEM, AI
  
  content        String?      @db.Text
  type           String       @default("text") // text, image, audio, video, document, location
  fileUrl        String?
  
  metadata       Json?
  isPrivate      Boolean      @default(false) // Notas internas
  mentions       WhatsappMention[]
  
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model ProspectingDecisionMaker {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  capturedLeadId String
  capturedLead   CapturedLead @relation(fields: [capturedLeadId], references: [id], onDelete: Cascade)

  name           String
  firstName      String?
  role           String?
  source         String       @default("manual")
  sourceUrl      String?
  priority       Int          @default(99)
  confidenceScore Int         @default(0)
  evidence       Json?
  isSelected     Boolean      @default(false)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([capturedLeadId])
  @@index([confidenceScore])
}

model ProspectingDispatchAttempt {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  runId          String
  run            ProspectingRun @relation(fields: [runId], references: [id], onDelete: Cascade)
