  success        Boolean  @default(true)
  errorMessage   String?

  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([agentType])
}

model AiModel {
  id             String   @id @default(uuid())
  name           String
  displayName    String
  provider       String   @default("local")
  runtime        String   @default("ollama")
