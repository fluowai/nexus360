  modelId         String?
  model           AiModel?      @relation("PrimaryAiModel", fields: [modelId], references: [id])
  fallbackModelId String?
  fallbackModel   AiModel?      @relation("FallbackAiModel", fields: [fallbackModelId], references: [id])
  temperature     Float         @default(0.4)
  maxTokens       Int           @default(2048)
