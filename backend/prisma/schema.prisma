  canalPrincipal  String?
  ferramentas     String?
  timeComercial   Int?
  queixas         String?
  scoreMaturidade Float?
  gargalos        Json?
  topPrioridades  Json?
  plano30_60_90   Json?
  status          String       @default("draft")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  icps            AcpIcp[]
  offers          AcpOffer[]

  @@index([organizationId])
}

model AcpIcp {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  diagnosisId     String?
  diagnosis       AcpDiagnosis? @relation(fields: [diagnosisId], references: [id])
  nome            String
  criterios       Json
  mensagem        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  offers          AcpOffer[]

  @@index([organizationId])
}

model AcpOffer {
  id              String      @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  diagnosisId     String?
  diagnosis       AcpDiagnosis? @relation(fields: [diagnosisId], references: [id])
  icpId           String?
  icp             AcpIcp?      @relation(fields: [icpId], references: [id])
  titulo          String
  elementos       Json
  valueStack      Json?
  ancoragem       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
}

model AcpAgentExecution {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId         String
  agentName       String
  input           String       @db.Text
  output          String       @db.Text
  metadata        Json?
  createdById     String?
  createdAt       DateTime     @default(now())

  @@index([organizationId])
  @@index([agentId])
}

model AcpObjection {
