  capturedLead   CapturedLead?            @relation(fields: [capturedLeadId], references: [id])
  crmLeadId      String?

  status         String                   @default("queued") // queued, active, qualified, nurturing, human_handoff, lost, stopped
  channel        String                   @default("WHATSAPP")
  leadName       String
  leadPhone      String?
  leadSnapshot   Json?
  score          Int                      @default(0)
  qualification  Json?
  firstMessage   String?                  @db.Text
  lastAiSummary  String?                  @db.Text
